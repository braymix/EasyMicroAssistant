# ============================================================
# Configurazione Knowledge Assistant
# Copia questo file come .env e personalizza i valori
# Comando: copy .env.example .env
# ============================================================

# Porta su cui accedere a Open WebUI (default: 3000)
# Dopo l'avvio, apri il browser su http://localhost:3000
OPEN_WEBUI_PORT=3000

# Chiave segreta per le sessioni web (generala con: openssl rand -hex 32)
# Se non impostata, ogni riavvio del container invaliderà le sessioni
# e dovrai rifare il login
WEBUI_SECRET_KEY=

# Abilita la registrazione di nuovi utenti (true/false)
# Il primo utente che si registra diventa automaticamente admin
# Dopo aver creato l'admin, puoi metterlo a false per bloccare nuove registrazioni
ENABLE_SIGNUP=true

# Modello da scaricare automaticamente all'avvio (opzionale)
# Esempi: llama3.2:3b (leggero, ~2GB), llama3.2:8b (medio, ~4.7GB)
# Lista completa dei modelli: https://ollama.com/library
DEFAULT_MODEL=llama3.2:3b
